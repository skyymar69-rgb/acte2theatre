# Sanity (récupérer ces valeurs sur https://sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01

# Token avec permissions d'écriture pour les preview/draft (optionnel en prod)
SANITY_API_READ_TOKEN=

# Secret partagé pour le webhook de revalidation ISR
# Doit correspondre à la valeur configurée dans Sanity > API > Webhooks
SANITY_REVALIDATE_SECRET=change_me_to_a_random_string

# URL canonique du site (utilisée pour les sitemaps, OG, etc.)
NEXT_PUBLIC_SITE_URL=https://www.acte2theatre.fr
