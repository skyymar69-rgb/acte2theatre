# Sanity (récupérer ces valeurs sur https://sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01

# Token avec permissions de lecture (utile pour les preview/draft, optionnel en prod)
SANITY_API_READ_TOKEN=

# Secret partagé pour le webhook de revalidation ISR
# Doit correspondre à la valeur configurée dans Sanity > API > Webhooks
SANITY_REVALIDATE_SECRET=change_me_to_a_random_string

# URL canonique du site (utilisée pour les sitemaps, OG, etc.)
NEXT_PUBLIC_SITE_URL=https://www.acte2theatre.fr

# ──────────────────────────────────────────────────────────────────────────────
# Auth Basic du Studio Sanity (/studio)
#   - Première barrière (popup navigateur) avant l'auth Sanity native.
#   - À configurer impérativement en prod (sinon /studio est ouvert au crawl).
# ──────────────────────────────────────────────────────────────────────────────
STUDIO_BASIC_AUTH_USER=Acte2Studio
STUDIO_BASIC_AUTH_PASS=change_me_to_a_strong_password

# ──────────────────────────────────────────────────────────────────────────────
# Email transactionnel via Resend (https://resend.com)
#   - Si RESEND_API_KEY est vide, /api/contact log les messages au lieu de les
#     envoyer (utile en dev). En prod : créer un compte Resend, vérifier le
#     domaine acte2theatre.fr et coller la clef ici.
# ──────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
CONTACT_TO_EMAIL=acte2theatre@yahoo.fr
CONTACT_FROM_EMAIL=site@acte2theatre.fr
